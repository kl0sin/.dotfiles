{
  "title": "Caps Lock → Hyper (ctrl+cmd+alt) / Escape (tap)",
  "rules": [
    {
      "description": "Caps Lock: hold = Hyper (ctrl+cmd+alt), tap = Escape",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "caps_lock",
            "modifiers": { "optional": ["any"] }
          },
          "to": [
            {
              "key_code": "left_control",
              "modifiers": ["left_command", "left_option"]
            }
          ],
          "to_if_alone": [
            {
              "key_code": "escape"
            }
          ]
        }
      ]
    }
  ]
}
